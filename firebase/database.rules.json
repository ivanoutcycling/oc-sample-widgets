{
  "rules": {
    ".read": false,
    ".write": false,

    "eventRoster": {
      "$eventId": {
        ".read": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
        ".write": false
      }
    },

    "meta": {
      "$eventId": {
        ".read": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
        ".write": false
      }
    },

    "checkins": {
      "$eventId": {
        ".read": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
        "$orderNumber": {
          ".write": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
          ".validate": "newData.hasChildren(['checkedIn', 'by']) || !newData.exists()",
          "checkedIn": { ".validate": "newData.isBoolean()" },
          "by": { ".validate": "newData.isString() && newData.val() == auth.token.email" },
          "at": { ".validate": "newData.isNumber() || newData.val() == now" },
          "$other": { ".validate": false }
        }
      }
    },

    "jerseys": {
      "$eventId": {
        ".read": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
        "$orderNumber": {
          ".write": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
          ".validate": "newData.hasChildren(['pickedUp', 'by']) || !newData.exists()",
          "pickedUp": { ".validate": "newData.isBoolean()" },
          "by": { ".validate": "newData.isString() && newData.val() == auth.token.email" },
          "at": { ".validate": "newData.isNumber() || newData.val() == now" },
          "$other": { ".validate": false }
        }
      }
    },

    "restricted": {
      ".read": "auth != null && auth.token.email_verified == true && (auth.token.email == 'pres@outcycling.org' || auth.token.email == 'med@outcycling.org')",

      "emergencyContacts": {
        "$eventId": { ".write": false }
      },

      "auditLog": {
        "$eventId": {
          "$entry": {
            ".write": "!data.exists() && newData.exists() && auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
            ".validate": "newData.hasChildren(['ts', 'actor', 'action'])",
            "actor":  { ".validate": "newData.val() == auth.token.email" },
            "action": { ".validate": "newData.isString()" },
            "target": { ".validate": "newData.isString()" },
            "ts":     { ".validate": "newData.val() == now || newData.isNumber()" },
            "$other": { ".validate": false }
          }
        }
      }
    }
  }
}
