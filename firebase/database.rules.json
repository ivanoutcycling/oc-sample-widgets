{
  "//": "Realtime Database security rules for the OutCycling volunteer dashboard.",
  "//1": "Enforcement layer — the client only HINTS at the org domain; access is decided here.",
  "//2": "eventRoster: read by any verified @outcycling.org user; written only by the Apps",
  "//3": "  Script sync (a service account / Admin token, which bypasses these rules).",
  "//4": "checkins: read + written by any verified @outcycling.org user, with light validation.",
  "rules": {
    ".read": false,
    ".write": false,

    "eventRoster": {
      "$eventId": {
        ".read": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
        ".write": false
      }
    },

    "meta": {
      "$eventId": {
        ".read": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
        ".write": false
      }
    },

    "checkins": {
      "$eventId": {
        ".read": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
        "$orderNumber": {
          ".write": "auth != null && auth.token.email_verified == true && auth.token.email.matches(/@outcycling[.]org$/)",
          ".validate": "newData.hasChildren(['checkedIn', 'by']) || !newData.exists()",
          "checkedIn": { ".validate": "newData.isBoolean()" },
          "by": { ".validate": "newData.isString() && newData.val() == auth.token.email" },
          "at": { ".validate": "newData.isNumber() || newData.val() == now" },
          "$other": { ".validate": false }
        }
      }
    }
  }
}
